{
  "expo": {
    "name": "myFamiPedia",
    "slug": "myfamipedia",
    "scheme": "myfamipedia",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow myFamiPedia to access your microphone to record interview answers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow myFamiPedia to access your photos so you can add them to family memories."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow myFamiPedia to scan your photo library for new photos that might be family memories.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.azerguia.myfamipedia",
      "associatedDomains": ["applinks:app.myfamipedia.com"]
    },
    "android": {
      "package": "com.azerguia.myfamipedia",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "app.myfamipedia.com", "pathPrefix": "/invite" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    }
  }
}
